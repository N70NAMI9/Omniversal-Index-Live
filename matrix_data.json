<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>N7 MATRIX // CINEMATIC DATABASE</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Syncopate:wght@700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-base: #000000;
            --bg-surface: #0f0f0f;
            --accent: #00f0ff;
            --text-main: #ffffff;
            --text-muted: #9ca3af; 
            --text-dark: #6b7280;
            --border-subtle: #222222;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg-base); color: var(--text-main);
            font-family: 'Inter', sans-serif; display: flex; min-height: 100vh;
            overflow-x: hidden;
        }

        /* Subtle Cinematic Grain */
        body::after {
            content: ""; position: fixed; inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03; pointer-events: none; z-index: 9999;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: 260px; height: 100vh; position: fixed; top: 0; left: 0;
            background: var(--bg-base); border-right: 1px solid var(--border-subtle);
            padding: 2.5rem 1.5rem; display: flex; flex-direction: column; z-index: 100;
        }

        .brand-logo { font-family: 'Syncopate', sans-serif; font-size: 1.4rem; font-weight: 700; letter-spacing: -1px; margin-bottom: 0.2rem; }
        .brand-logo span { color: var(--accent); }
        .brand-sub { font-size: 0.65rem; color: var(--text-dark); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 2.5rem; }

        .search-box {
            width: 100%; padding: 0.8rem 1rem; background: var(--bg-surface);
            border: 1px solid var(--border-subtle); border-radius: 4px;
            color: var(--text-main); font-family: 'Inter'; font-size: 0.85rem;
            margin-bottom: 2rem; outline: none; transition: border 0.3s ease;
        }
        .search-box:focus { border-color: var(--accent); }

        .nav-label { font-size: 0.7rem; font-weight: 600; color: var(--text-dark); margin-bottom: 1rem; letter-spacing: 1px; text-transform: uppercase; }

        .category-list { list-style: none; display: flex; flex-direction: column; gap: 0.2rem; overflow-y: auto; }
        .category-list::-webkit-scrollbar { display: none; }

        .cat-btn {
            background: transparent; border: none; color: var(--text-muted);
            font-family: 'Inter'; font-size: 0.85rem; text-align: left;
            padding: 0.6rem 0.8rem; border-radius: 4px; transition: all 0.2s ease;
            cursor: pointer; width: 100%; font-weight: 500;
        }
        .cat-btn:hover { color: var(--text-main); background: var(--bg-surface); }
        .cat-btn.active { color: var(--bg-base); background: var(--accent); font-weight: 600; }

        /* --- MAIN CONTENT (IMDB FEED) --- */
        .main-wrapper { 
            margin-left: 260px; padding: 3rem 4rem; width: calc(100% - 260px);
            display: flex; flex-direction: column; align-items: center;
        }

        .content-container { width: 100%; max-width: 950px; }

        .page-header { border-bottom: 1px solid var(--border-subtle); padding-bottom: 1rem; margin-bottom: 2rem; }
        .breadcrumbs { font-size: 0.75rem; color: var(--text-dark); margin-bottom: 0.5rem; letter-spacing: 1px; text-transform: uppercase; font-weight: 600;}
        .page-title { font-size: 2rem; font-weight: 700; letter-spacing: -0.5px; color: #fff; }

        .cinematic-feed { display: flex; flex-direction: column; width: 100%; }

        /* ELITE IMDB STYLE CARD */
        .pro-card {
            display: flex; gap: 2rem; padding: 2.5rem 0;
            border-bottom: 1px solid var(--border-subtle);
            transition: all 0.3s ease; opacity: 0; transform: translateY(10px);
            animation: fadeUpIn 0.5s ease forwards;
        }

        @keyframes fadeUpIn { to { opacity: 1; transform: translateY(0); } }

        /* Movie Poster Aspect Ratio (2:3) */
        .card-visual { 
            width: 180px; flex-shrink: 0; border-radius: 4px; overflow: hidden; 
            aspect-ratio: 2 / 3; background: #111;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }
        .card-visual img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.85) contrast(1.1); transition: filter 0.3s ease; }
        .pro-card:hover .card-visual img { filter: brightness(1) contrast(1.05); }

        .card-data { display: flex; flex-direction: column; justify-content: flex-start; flex-grow: 1; overflow: hidden; }
        
        .card-heading { font-size: 1.4rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.3rem; color: #fff; }
        
        .card-meta { display: flex; gap: 1rem; font-size: 0.8rem; color: var(--text-dark); margin-bottom: 1rem; font-weight: 500; }
        .card-meta span { display: flex; align-items: center; gap: 0.3rem; }
        
        .card-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.2rem; }
        .pro-tag { border: 1px solid #333; color: #d1d5db; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.7rem; font-weight: 500; text-transform: capitalize; }

        /* Read More Truncation Logic */
        .card-text { 
            font-size: 0.95rem; line-height: 1.7; color: var(--text-muted); 
            white-space: pre-wrap; font-weight: 400; margin-bottom: 1rem;
            display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
            transition: all 0.3s ease;
        }
        .card-text.expanded { -webkit-line-clamp: unset; }
        .highlight { color: #fff; font-weight: 600; }

        .read-more-btn {
            background: transparent; border: none; color: var(--accent); font-weight: 600;
            font-size: 0.85rem; cursor: pointer; text-align: left; align-self: flex-start;
            text-transform: uppercase; letter-spacing: 1px; padding: 0;
        }
        .read-more-btn:hover { text-decoration: underline; }

        .mobile-menu-btn { display: none; position: fixed; top: 1rem; right: 1rem; z-index: 1000; background: var(--bg-surface); border: 1px solid var(--border-subtle); padding: 0.5rem 0.8rem; border-radius: 4px; color: #fff; font-size: 0.8rem; cursor: pointer;}

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        /* === RESPONSIVE LAYOUT === */
        @media (max-width: 992px) {
            .sidebar { left: -100%; transition: left 0.4s ease; }
            .sidebar.open { left: 0; }
            .mobile-menu-btn { display: block; }
            .main-wrapper { margin-left: 0; width: 100%; padding: 4rem 1.5rem 2rem 1.5rem; }
        }

        @media (max-width: 600px) {
            .pro-card { flex-direction: column; gap: 1rem; padding: 2rem 0; }
            /* On mobile, poster goes full width like a banner, or stays small. Let's make it look like a nice banner */
            .card-visual { width: 100%; aspect-ratio: 16 / 9; } 
            .card-heading { font-size: 1.2rem; }
            .page-title { font-size: 1.6rem; }
        }
    </style>
</head>
<body>
    <button class="mobile-menu-btn" onclick="document.querySelector('.sidebar').classList.toggle('open')">MENU</button>

    <aside class="sidebar">
        <div class="brand-logo">N7<span>MATRIX</span></div>
        <div class="brand-sub">Film Database</div>
        <input type="text" id="searchInput" class="search-box" placeholder="Search intel..." onkeyup="filterBySearch()">
        <div class="nav-label">Categories</div>
        <ul class="category-list" id="category-menu"></ul>
    </aside>

    <main class="main-wrapper">
        <div class="content-container">
            <div class="page-header">
                <div class="breadcrumbs">INDEX / <span id="bread-current" style="color: var(--accent);">ALL OPERATIONS</span></div>
                <h1 class="page-title" id="page-heading">Global Telemetry</h1>
            </div>
            <section class="cinematic-feed" id="matrix-grid"></section>
        </div>
    </main>

    <script>
        let globalData = [];

        function getSafeTags(tagData) {
            if (!tagData) return [];
            if (Array.isArray(tagData)) return tagData.map(t => String(t).replace(/\[|\]/g, '').trim());
            if (typeof tagData === 'string') return tagData.split(',').map(t => t.replace(/\[|\]/g, '').trim());
            return [];
        }

        async function bootMatrix() {
            try {
                const response = await fetch('matrix_data.json?t=' + Date.now());
                if (!response.ok) throw new Error(`HTTP Error ${response.status}`);
                
                let parsedData = JSON.parse(await response.text());
                if (!Array.isArray(parsedData)) parsedData = [parsedData]; 

                // Duplicate Killer Logic
                const uniqueData = [];
                const seenTitles = new Set();
                parsedData.reverse().forEach(item => {
                    const safeTitle = item.title ? item.title.toLowerCase().trim() : "unknown";
                    if (!seenTitles.has(safeTitle)) {
                        seenTitles.add(safeTitle);
                        uniqueData.push(item);
                    }
                });

                globalData = uniqueData;
                buildTaxonomy();
                renderFeed(globalData);

            } catch (error) {
                document.getElementById('matrix-grid').innerHTML = `<p style="color: #ef4444;">Database Offline: ${error.message}</p>`;
            }
        }

        function buildTaxonomy() {
            const menu = document.getElementById('category-menu');
            let html = `<li><button class="cat-btn active" onclick="filterCategory('All', this)">All Operations</button></li>`;
            
            const uniqueTags = new Set();
            globalData.forEach(entry => getSafeTags(entry.category_tags).forEach(tag => { if(tag) uniqueTags.add(tag); }));

            uniqueTags.forEach(tag => {
                html += `<li><button class="cat-btn" onclick="filterCategory('${tag}', this)">${tag}</button></li>`;
            });
            menu.innerHTML = html;
        }

        window.filterCategory = function(tag, btnElement) {
            document.querySelectorAll('.cat-btn').forEach(btn => btn.classList.remove('active'));
            btnElement.classList.add('active');
            
            document.getElementById('page-heading').innerText = tag === 'All' ? 'Global Telemetry' : tag;
            document.getElementById('bread-current').innerText = tag;
            document.getElementById('searchInput').value = ''; 

            const filtered = tag === 'All' ? globalData : globalData.filter(e => getSafeTags(e.category_tags).includes(tag));
            renderFeed(filtered);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.filterBySearch = function() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('.cat-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('page-heading').innerText = query ? `Search: "${query}"` : 'Global Telemetry';
            
            const filtered = globalData.filter(e => 
                (e.title && e.title.toLowerCase().includes(query)) || 
                (e.content && e.content.toLowerCase().includes(query))
            );
            renderFeed(filtered);
        }

        // Toggle Expand/Collapse
        window.toggleRead = function(btn) {
            const textContainer = btn.previousElementSibling;
            if (textContainer.classList.contains('expanded')) {
                textContainer.classList.remove('expanded');
                btn.innerText = 'READ FULL REPORT ˅';
            } else {
                textContainer.classList.add('expanded');
                btn.innerText = 'COLLAPSE ˄';
            }
        }

        function renderFeed(dataBlock) {
            const grid = document.getElementById('matrix-grid');
            grid.innerHTML = ''; 

            if(dataBlock.length === 0) {
                grid.innerHTML = `<p style="color: #6b7280;">No records found.</p>`;
                return;
            }

            dataBlock.forEach((entry, index) => {
                const card = document.createElement('article');
                card.className = 'pro-card';
                card.style.animationDelay = `${index * 0.1}s`; 

                const tagsHtml = getSafeTags(entry.category_tags).map(tag => `<span class="pro-tag">${tag}</span>`).join('');
                
                let safeContent = entry.content || "No data recovered.";
                let formattedContent = safeContent.replace(/\*\*(.*?)\*\*/g, '<span class="highlight">$1</span>');
                
                const safeTitle = entry.title || "Classified Intel";
                // Vertical Poster Fallback
                const safeImage = entry.image_url || "https://images.unsplash.com/photo-1440404653325-ab127d49abc1?q=80&w=600&auto=format&fit=crop";
                const safeId = entry.id ? entry.id.substring(0,8) : "N/A";
                const safeTime = entry.timestamp ? new Date(entry.timestamp).toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'}) : "Unknown Date";

                card.innerHTML = `
                    <div class="card-visual">
                        <img src="${safeImage}" alt="Poster" loading="lazy"
                             onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1440404653325-ab127d49abc1?q=80&w=600&auto=format&fit=crop';" />
                    </div>
                    <div class="card-data">
                        <h2 class="card-heading">${safeTitle}</h2>
                        <div class="card-meta">
                            <span>ID: ${safeId}</span> • <span>${safeTime}</span>
                        </div>
                        <div class="card-tags">${tagsHtml}</div>
                        <div class="card-text">${formattedContent}</div>
                        <button class="read-more-btn" onclick="toggleRead(this)">READ FULL REPORT ˅</button>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        document.addEventListener('DOMContentLoaded', bootMatrix);
    </script>
</body>
</html>
